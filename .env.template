# TurboQuant VLA for Raspberry Pi 4B — Development Environment
# TARGET: HiWonder TurboPi (Raspberry Pi 4B, ARM Cortex-A72, 4GB RAM)
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it may contain secrets)

# Python & Environment
PYTHON_VERSION=3.11
VENV_NAME=turboquant-vla-dev
TARGET_DEVICE=raspberry_pi_4b

# Development Machine (for simulation)
# Options: cpu, cuda, mps (Apple Silicon)
DEVICE=cpu
# For GPU development: cuda (RTX 4050 simulation)
# For Mac development: mps

# Model Configuration
OCTO_MODEL_ID=google/octo-base-1B
PI0_MODEL_ID=  # To be determined
LEROBOT_MODEL_ID=  # To be determined

# TurboQuant Settings
# Quantization bit-width: 3, 4, or 8
QUANTIZATION_BITS=4

# Residual window size (tokens to keep in FP16)
RESIDUAL_WINDOW_SIZE=512

# Calibration settings
CALIBRATION_SAMPLES=100
CALIBRATION_BATCH_SIZE=1

# Inference Settings
INFERENCE_BATCH_SIZE=1
MAX_SEQUENCE_LENGTH=2000

# Benchmark Settings
BENCHMARK_RUNS=10
BENCHMARK_WARMUP=2

# Paths (relative to project root)
DATA_DIR=data
MODELS_DIR=models
RESULTS_DIR=results
LOGS_DIR=logs
DOCS_DIR=docs

# API Keys (if using HuggingFace auth)
HUGGINGFACE_TOKEN=

# Raspberry Pi 4B (TurboPi) Deployment
TARGET_PI_HOST=turbopi.local      # or: pi-4b.local, 192.168.x.x
TARGET_PI_USER=pi                 # Default Pi username
TARGET_PI_SSH_KEY=~/.ssh/pi_rsa   # SSH key for Pi access
TARGET_PI_MEMORY_GB=4             # Pi 4B has 4GB total
TARGET_PI_AVAILABLE_GB=3           # ~3GB available for ML (after OS overhead)
TARGET_PI_CPU_CORES=4              # Quad-core ARM Cortex-A72
TARGET_PI_CPU_FREQ_GHZ=1.5         # Base frequency 1.5 GHz

# Flags
SKIP_CALIBRATION=false
SKIP_VALIDATION=false
USE_MIXED_PRECISION=false

# Experimental (advanced)
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=profiles
SAVE_INTERMEDIATE_TENSORS=false
